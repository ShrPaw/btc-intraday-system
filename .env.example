# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Binance Futures (for live trading — leave empty for paper-only mode)
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Paper trading mode (true = no real orders, false = execute via ccxt)
PAPER_MODE=true

# Paper mode equity (used when PAPER_MODE=true, ignored in live)
PAPER_EQUITY=10000
